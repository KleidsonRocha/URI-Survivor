  m_Script: {fileID: 11500000, guid: 5d346bd46ede94148b1996d044e94645, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  stats:
  - speed: 0
    damage: 5
    range: 1
    timeBetweenAttacks: 1.6
    amount: 1
    duration: 1
    UpgradeText: "Exibe distor\xE7\xF5es visuais para desorientar e sobrecarregar
      a percep\xE7\xE3o do alvo."
  - speed: 0
    damage: 7
    range: 1
    timeBetweenAttacks: 1.5
    amount: 2
    duration: 1.2
    UpgradeText: "Manipula o framebuffer diretamente, injetando padr\xF5es gr\xE1ficos
      que causam anomalias de renderiza\xE7\xE3o."
  - speed: 0
    damage: 9
    range: 1.1
    timeBetweenAttacks: 1.3
    amount: 3
    duration: 1.4
    UpgradeText: "Sobrecarga a VRAM (Video Random Access Memory) e o controlador
      de exibi\xE7\xE3o, induzindo falhas sist\xEAmicas na GUI."
  - speed: 0
    damage: 11
    range: 1.15
    timeBetweenAttacks: 1.2
    amount: 4
    duration: 2
    UpgradeText: Intercepta e altera os dados do DisplayPort ou HDMI, explorando
      o firmware do monitor para causar desligamento ou pane total.
  - speed: 0
    damage: 13
    range: 1.2
    timeBetweenAttacks: 1.15
    amount: 4
    duration: 2
    UpgradeText: "Explora falhas de seguran\xE7a no driver da GPU para obter controle
      total sobre o pipeline de renderiza\xE7\xE3o, permitindo a inje\xE7\xE3o de
      imagens arbitr\xE1rias e a filtragem de dados visuais sens\xEDveis."
  - speed: 0
    damage: 15
    range: 1.25
    timeBetweenAttacks: 1.05
    amount: 5
    duration: 2
    UpgradeText: ": Compromete o microc\xF3digo da GPU ou o firmware do controlador
      de v\xEDdeo da placa-m\xE3e, inserindo instru\xE7\xF5es maliciosas que manipulam
      a sa\xEDda de v\xEDdeo antes do boot do sistema operacional"
  weaponLevel: 0
  statsUpdated: 0
  icon: {fileID: 6864705659591406222, guid: bb9b43e0f32a24c44b440704e2b5ef9e, type: 3}
  damager: {fileID: 4121245524676404226}
